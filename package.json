{
  "name": "free-chess",
  "version": "1.11.0",
  "description": "Offline-first Android chess board and teaching app",
  "license": "MIT",
  "main": "index.ts",
  "expo": {
    "autolinking": {
      "nativeModulesDir": "./modules"
    }
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "chess.js": "^1.4.0",
    "expo": "~56.0.11",
    "expo-clipboard": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test .test-build/src/components/Board/boardCoordinates.test.js .test-build/src/data/lessons/lessonCatalog.test.js .test-build/src/engine/engineManager.test.js .test-build/src/engine/uci.test.js .test-build/src/game/chessState.test.js .test-build/src/game/clockState.test.js .test-build/src/game/customPosition.test.js .test-build/src/game/gameAnalysis.test.js .test-build/src/game/gameRecord.test.js .test-build/src/game/importedTraining.test.js .test-build/src/game/localAi.test.js .test-build/src/game/lessonRuntime.test.js .test-build/src/game/series.test.js .test-build/src/game/userProfile.test.js",
    "test:stockfish:android": "node scripts/verify-stockfish-android.mjs"
  },
  "private": true
}
